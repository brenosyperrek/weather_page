# Copie este arquivo para ".env" e ajuste os valores se necessario. O ".env" real
# nunca deve ser commitado (esta no .gitignore) -- aqui ficam so placeholders.

# Conexao com o Postgres que ja contem a tabela silver.capitais_weather.
# Dentro do docker-compose o host padrao e "postgres18" (nome do container na rede
# pipeline_dados_net); para rodar o backend fora do Docker, use "localhost".
WEATHER_DB_HOST=postgres18
WEATHER_DB_PORT=5432
WEATHER_DB_USER=postgres
WEATHER_DB_PASSWORD=changeme
WEATHER_DB_NAME=postgres

# Origens autorizadas a chamar a API (separadas por virgula, sem espaco).
WEATHER_CORS_ORIGINS=["http://localhost","http://localhost:5173"]
